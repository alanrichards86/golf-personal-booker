# WordPress page password to unlock the Fore Pass tee times page
FOREPASS_PASSWORD=FOREPASSHOLDER

# TeeItUp account credentials
TEEITUP_USERNAME=your-email@example.com
TEEITUP_PASSWORD=your-password

# Booking preferences
# TARGET_DAY_OF_WEEK: 0=Monday, 1=Tuesday, ..., 6=Sunday
TARGET_DAY_OF_WEEK=6
TARGET_HOUR_START=7
TARGET_HOUR_END=12
TARGET_NUM_GOLFERS=1

# DANGER: Set to true to auto-click "Complete your purchase" without human review
AUTO_COMPLETE_PURCHASE=false

# Optional: webhook for notifications (e.g., Slack, Discord, Zapier)
WEBHOOK_URL=
